# Copy to src/PeaceNest.Api/.env or configure these values through your shell,
# user-secrets, or Railway environment variables. Never commit real secrets.

# Runtime database connection. Use Supabase session pooler for the deployed API.
ConnectionStrings__PeaceNest="Host=<session-pooler-host>;Port=5432;Database=postgres;Username=postgres.<project-ref>;Password=<database-password>;SSL Mode=Require;Trust Server Certificate=true;Pooling=true"

# Optional direct database connection for deliberate local migration commands.
# Use this only for migration/application from a trusted machine.
ConnectionStrings__PeaceNestMigration="Host=<direct-db-host>;Port=5432;Database=postgres;Username=postgres;Password=<database-password>;SSL Mode=Require;Trust Server Certificate=true"

# Supabase Auth JWT validation.
Authentication__Supabase__ProjectUrl="https://<project-ref>.supabase.co"
Authentication__Supabase__Audience="authenticated"
