{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authentication": {
    "Supabase": {
      "ProjectUrl": "",
      "Audience": "authenticated"
    }
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 300,
      "WindowSeconds": 60
    },
    "Auth": {
      "PermitLimit": 20,
      "WindowSeconds": 60
    },
    "Write": {
      "PermitLimit": 60,
      "WindowSeconds": 60
    },
    "Invite": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "RecapGeneration": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    }
  },
  "AllowedHosts": "*"
}
