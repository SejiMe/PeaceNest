{
  "name": "peacenest",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "src/PeaceNest.App"
  ],
  "scripts": {
    "tunnel:app": "npm --prefix src/PeaceNest.App run start -- --tunnel",
    "start": "npm --prefix src/PeaceNest.App run start",
    "android": "npm --prefix src/PeaceNest.App run android",
    "web": "npm --prefix src/PeaceNest.App run web",
    "typecheck": "npm --prefix src/PeaceNest.App run typecheck",
    "api": "dotnet run --project src/PeaceNest.Api/PeaceNest.Api.csproj",
    "api:build": "dotnet build PeaceNest.slnx",
    "api:test": "dotnet test PeaceNest.slnx",
    "api:migrate": "dotnet ef database update --project src/PeaceNest.Api/PeaceNest.Api.csproj --startup-project src/PeaceNest.Api/PeaceNest.Api.csproj",
    "docker:build": "docker build -t peacenest-api:local .",
    "docker:run": "docker run --rm -p 8080:8080 --env-file src/PeaceNest.Api/.env peacenest-api:local",
    "web:export": "npm --prefix src/PeaceNest.App run web:export"
  }
}
